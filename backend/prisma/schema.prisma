generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  entries    JournalEntry[]
  trades     Trade[]
  propAccounts PropAccount[]
}

model SignupVerification {
  id        String   @id @default(uuid())
  email     String
  code      String   // hashed 6-digit OTP
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PropAccount {
  id           String   @id @default(uuid())
  firmName     String   // e.g., "The Funded Room"
  accountType  String   // "1_STEP", "2_STEP", "INSTANT"
  accountSize  Float
  status       String   // "PHASE_1", "PHASE_2", "FUNDED", "FAILED"
  
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  hasHftWarning Boolean @default(false)
  
  trades       Trade[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Trade {
  id           String   @id @default(uuid())
  symbol       String
  volume       String   // e.g "0.05/0.05"
  entryPrice   Float
  closePrice   Float
  pnl          Float
  netPnl       Float
  chargesSwap  String   // e.g "0.00/0.00"
  openedAt     DateTime
  closedAt     DateTime
  orderId      String   @unique
  status       String   // e.g "Closed"
  side         String?  // "Long", "Short"
  broker       String   @default("vantage") // e.g "vantage", "the_funded_room"

  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  
  propAccountId String?
  propAccount   PropAccount? @relation(fields: [propAccountId], references: [id], onDelete: Cascade)
  accountPhase  String?  // e.g "PHASE_1", "PHASE_2", "FUNDED"

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model JournalEntry {
  id        String   @id @default(uuid())
  date      DateTime
  subject   String
  text      String
  tags      String[]
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  token     String   // bcrypt-hashed 6-digit OTP
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}
